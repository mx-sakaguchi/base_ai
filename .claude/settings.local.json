{
  "permissions": {
    "allow": [
      "Bash(uv sync:*)",
      "Bash(uv lock:*)",
      "Bash(uv add:*)",
      "Bash(uv remove:*)",
      "Bash(uv run:*)",
      "Bash(uv run uvicorn:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run python -m pytest:*)",
      "Bash(uv python:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git ls-files:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(python -c \"import ast; ast.parse(open('app/main.py').read()); print('main.py: OK')\")",
      "Bash(python -c \"import json; json.load(open('.devcontainer/devcontainer.json')); print('devcontainer.json: OK')\")",
      "Bash(python -c \"import json; json.load(open('.claude/settings.local.json')); print('settings.local.json: OK')\")"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(rmdir:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(chmod 777:*)",
      "Bash(chown:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(kill -9 -1:*)",
      "Bash(killall:*)",
      "Bash(> .env:*)",
      "Bash(tee .env:*)"
    ]
  },
  "excludeFiles": [
    ".env",
    ".env.local",
    ".env.production",
    ".venv/**",
    ".git/**",
    "node_modules/**",
    "*.pem",
    "*.key",
    "*.p12",
    "*.pfx",
    "secrets.json",
    "credentials.json"
  ]
}
